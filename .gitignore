.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Large raw/proprietary market data stays local.
MD/*.csv
data/raw/
data/processed/

# Keep the small sample dataset for reproducibility.
!data/sample/
!data/sample/*.parquet

# Heavy generated time series can be reproduced.
reports/tables/*.parquet
reports/liquidation_eda/tables/*.parquet
reports/liquidation_eda/cache/

# Keep lightweight report CSVs, figures, and markdown report in git.

# Research papers can be stored locally for agents, but PDFs/books are usually
# large and may be copyrighted. Track notes and metadata, not the binaries.
docs/research/papers/*
!docs/research/papers/.gitkeep
